# Copy to .env (gitignored) and fill in. Never commit real values.
export GOVC_URL="https://<esxi-or-vcenter-host>/sdk"
export GOVC_USERNAME="root"
export GOVC_PASSWORD="<password>"
export GOVC_INSECURE=1

# Lab VM / target settings
export LAB_VM="cryptos-lab"
export LAB_DATASTORE="DATASTORE"
export LAB_NETWORK="Datacenter"
export LAB_ISO_PATH="ISO/cryptos-amd64-vmware.iso"   # datastore-relative
export LAB_ISO_LOCAL="build/out/cryptos-amd64-vmware.iso"
export LAB_DISK_GB="20"
